# =============================================================================
# Application Configuration
# =============================================================================

# Database (PostgreSQL) - connection string
# Run `bash setup-postgres.sh` to install and start a local PostgreSQL instance
DATABASE_URL=postgresql://app:app@localhost:5432/app_db

# JWT secret for session tokens - generate with: openssl rand -hex 32
JWT_SECRET=

# Application URL (used in emails for links)
APP_URL=http://localhost:8497

# Server port
PORT=8497

# =============================================================================
# Email (SMTP) - Optional: emails log to console if not configured
# =============================================================================

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=My App <noreply@example.com>

# =============================================================================
# Stripe - Optional: billing features disabled if not configured
# =============================================================================

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
